# Context-OS Environment Variables
# Copy this file to .env and fill in all values before running.
# ─────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (asyncpg driver) — matches docker/docker-compose.yml defaults
DATABASE_URL=postgresql+asyncpg://contextos:contextospass@localhost:5432/contextosdb

# ── Clerk Authentication ───────────────────────────────────────────────────────
# Obtain from https://dashboard.clerk.com → Your App → API Keys
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here
CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here

# ── Langfuse Observability ─────────────────────────────────────────────────────
# Obtain from http://localhost:3000 → Settings → API Keys (after docker compose up)
# Or from https://cloud.langfuse.com for cloud-hosted Langfuse
LANGFUSE_PUBLIC_KEY=pk-lf-1234567890abcdef
LANGFUSE_SECRET_KEY=sk-lf-1234567890abcdef
LANGFUSE_HOST=http://localhost:3000

# ── Token Encryption ───────────────────────────────────────────────────────────
# Fernet AES-256 key for encrypting OAuth tokens at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-base64-encoded-32-byte-key-here

# ── GitHub App ─────────────────────────────────────────────────────────────────
# Obtain from https://github.com/settings/apps → Your App → General
# GITHUB_APP_ID: numeric App ID shown on the App settings page
GITHUB_APP_ID=123456
# GITHUB_APP_PRIVATE_KEY_PATH: path to the .pem file downloaded from App settings
GITHUB_APP_PRIVATE_KEY_PATH=./secrets/github-app.pem
# GITHUB_INSTALLATION_ID: numeric installation ID from GitHub App → Installations
GITHUB_INSTALLATION_ID=12345678

# ── Jira Cloud OAuth 2.0 ───────────────────────────────────────────────────────
# Obtain from https://developer.atlassian.com/console/myapps/ → Your App → Authorization
JIRA_CLIENT_ID=your_jira_oauth_client_id
JIRA_CLIENT_SECRET=your_jira_oauth_client_secret

# ── Slack Bot Token ────────────────────────────────────────────────────────────
# Obtain from https://api.slack.com/apps → Your App → OAuth & Permissions → Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here
# Comma-separated Slack channel IDs to ingest (e.g. C0123ABC,C0456DEF)
# Find channel IDs in Slack → Right-click channel → View channel details → Copy ID
SLACK_CHANNEL_IDS=C0123ABCDEF,C0456GHIJKL
