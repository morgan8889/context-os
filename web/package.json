{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots",
    "benchmark:galaxy": "tsx scripts/benchmark-galaxy.ts",
    "benchmark:topology": "tsx scripts/benchmark-topology.ts",
    "benchmark:decisions": "tsx scripts/benchmark-decisions.ts"
  },
  "dependencies": {
    "@clerk/react": "^6.6.6",
    "@dagrejs/dagre": "^1.1.4",
    "@gsap/react": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.0",
    "@react-sigma/core": "^4.0.0",
    "@react-sigma/layout-forceatlas2": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/react-query": "^5.40.0",
    "@xyflow/react": "^12.0.0",
    "axios": "^1.7.0",
    "framer-motion": "^11.2.0",
    "graphology": "^0.25.4",
    "graphology-layout-forceatlas2": "^0.10.1",
    "gsap": "^3.12.5",
    "immer": "^10.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^6.23.0",
    "sigma": "^3.0.3",
    "tailwindcss": "^4.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.6",
    "graphology-types": "^0.24.8",
    "jsdom": "^24.0.0",
    "prettier": "^3.2.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.0",
    "vite": "^6.0.0",
    "vitest": "^2.0.0"
  }
}
